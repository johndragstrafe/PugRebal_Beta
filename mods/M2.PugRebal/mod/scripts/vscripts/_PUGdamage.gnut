void function onSuccess_profiles( table t_untyped ) {
    // convert untyped table to typed table
    table<string, array<float> > t_typed;
    foreach (var key, var val in t_untyped) {
        string strkey = expect string(key);
        array arr_untyped = expect array(val);
        array<float> arr_typed = []
        foreach (var entry in arr_untyped) {
            // if you expect a float, but the entry doesnt have a decimal point, it fucking dies
            // use string instead, then cast to float (yes squirrel has cancer)
            string num_untyped = expect string(entry);
            float num_typed = num_untyped.tofloat();
            arr_typed.append( num_typed );
        }
        t_typed[strkey] <- arr_typed
    }
    coerse_cancerous_table_format( t_typed )
}

void function coerse_cancerous_table_format ( table< string, array<float> > t_cancer ) {
    // cancer workaround to NS JSON table limitations
    // build profile struct out of flat vec
    table<string, DamageProfile> converted;
    foreach (string key, array<float> vec in t_cancer) {
        if (vec.len() < 3) {
            printt("[STRAFE] bad custom profile format `" + key + "` | float vec must have 3 values (hsm, dist0, dmg0)")
            continue;
        }
        if ((vec.len() % 2) != 1) {
            printt("[STRAFE] bad custom profile format `" + key + "` | float vec must have an odd # of values (hsm, dist0, dmg0, dist1, dmg1 ...)")
            continue;
        }
        DamageProfile newprof;
        newprof.headshot_multiplier = vec[0]
        newprof.nodes = [];
        float profdistance = -1;
        int error = 0;
        for (int i = 1; i < vec.len(); i += 2) {
            DamageNode newnode;
            newnode.distance = vec[i];
            newnode.damage = vec[i+1];
            if (newnode.distance <= profdistance) { // i am not sorting these bro
                printt("[STRAFE] bad custom profile format `" + key + "` | distances must be in asc order")
                error = 1;
                break;
            }
            newprof.nodes.append(newnode)
        }
        if (error) {
            continue;
        }
        file.custom_profiles[key] <- newprof
    }
}

void function write_cancerous_table_format ( string filename ) {
    table<string, array<string> > t_cancer;
    foreach (string key, DamageProfile profile in file.custom_profiles) {
        // NS json doesnt support structs
        // have to use string because otherwise squirrel shits itself trying to read in floats
        array<string> flattened; 
        flattened.append(profile.headshot_multiplier.tostring());
        foreach(DamageNode node in profile.nodes) {
            flattened.append(node.distance.tostring())
            flattened.append(node.damage.tostring())
        }
        t_cancer[key] <- flattened;
    }
    NSSaveJSONFile(filename, t_cancer)
}



